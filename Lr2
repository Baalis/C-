#include <iostream>
#include <cmath>

int main() {
    // Ввод координат точки
    double x, y;
    std::cout << "Введите координаты точки (x, y): ";
    std::cin >> x >> y;

    // Определение радиуса заштрихованной области
    double R = 5.0;

    // Проверка попадания точки в заштрихованную область
    if ((x * x + y * y) <= R * R) {
        std::cout << "Точка попадает в заштрихованную область." << std::endl;
    } else {
        std::cout << "Точка не попадает в заштрихованную область." << std::endl;
    }

    return 0;
}
